{
  "name": "agentsocial",
  "version": "0.1.0",
  "private": true,
  "workspaces": [],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @agentsocial/api db:generate",
    "db:migrate": "pnpm --filter @agentsocial/api db:migrate",
    "db:studio": "pnpm --filter @agentsocial/api db:studio",
    "dev:api": "pnpm --filter @agentsocial/api dev",
    "dev:web": "pnpm --filter @agentsocial/web dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "*.{ts,tsx,js,mjs,css,md,json}": "prettier --write",
    "*.{ts,tsx}": "eslint --quiet --cache --fix"
  }
}
